generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  fullName     String
  email        String        @unique
  phone        String        @unique
  password     String
  role         String        @default("farmer")
  language     String        @default("en")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  crops        Crop[]
  diseaseScans DiseaseScan[]
}

model Crop {
  id                  String    @id @default(cuid())
  cropName            String
  cropVariety         String
  landArea            Float
  soilType            String
  irrigationMethod    String
  location            String
  latitude            Float
  longitude           Float
  sowingDate          DateTime
  expectedHarvestDate DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DiseaseScan {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?
  imageUrl   String?
  prediction String
  confidence Float
  crop       String?
  disease    String?
  severity   String?
  summary    String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AgriShop {
  id           String            @id @default(cuid())
  name         String
  phone        String?
  address      String
  district     String
  state        String
  latitude     Float
  longitude    Float
  isVerified   Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  shopProducts AgriShopProduct[]

  @@index([district, state])
}

model AgriProduct {
  id               String            @id @default(cuid())
  brandName        String
  productName      String
  category         String
  crop             String
  targetProblem    String
  activeIngredient String?
  formulation      String?
  dosageNote       String
  safetyNote       String
  organic          Boolean           @default(false)
  isVerified       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  shopProducts     AgriShopProduct[]

  @@index([crop, targetProblem])
  @@index([category])
}

model AgriShopProduct {
  id                 String      @id @default(cuid())
  shopId             String
  productId          String
  approximatePrice   Float?
  priceUnit          String?
  availabilityStatus String      @default("unknown")
  lastVerifiedAt     DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  shop               AgriShop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product            AgriProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId])
  @@index([shopId])
  @@index([productId])
}

